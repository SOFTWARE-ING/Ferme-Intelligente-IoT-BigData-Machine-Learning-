# ==========================================
# ManiChicks Backend - Environment Variables
# ==========================================

# Server
PORT=5000
NODE_ENV=development           # development | production

# MongoDB
# Format: mongodb://[username:password@]host:port/database?authSource=admin
MONGODB_URI=mongodb://username:password@localhost:27018/manichicks_db?authSource=admin

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_here   # change this in production
JWT_EXPIRE=30d                              # token expiration (7d, 30d, etc.)

# MQTT (for Packet Tracer IoT integration)
MQTT_BROKER=mqtt://localhost:1883
MQTT_USERNAME=                              # optional, leave empty if none
MQTT_PASSWORD=                              # optional

# WebSocket (Socket.IO)
SOCKET_PORT=5001

# Email (SMTP) – for notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password